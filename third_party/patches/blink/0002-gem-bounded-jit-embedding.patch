+bool blink_gem_machine_jit_info(const struct blink_gem_machine* g,
+                                struct blink_gem_jit_info* out) {
+  if (!g || !out || out->abi_version != BLINK_GEM_JIT_INFO_ABI_VERSION ||
+      out->size != sizeof(*out))
+    return false;
+  out->engine_mode = g->engine_mode;
+#if defined(__aarch64__)
+  out->host_architecture = BLINK_GEM_HOST_AARCH64;
+#elif defined(__x86_64__)
+  out->host_architecture = BLINK_GEM_HOST_X86_64;
+#else
+  out->host_architecture = BLINK_GEM_HOST_UNKNOWN;
+#endif
+  out->cache_capacity_bytes =
+      g->engine_mode == BLINK_GEM_ENGINE_JIT ? BLINK_GEM_JIT_CACHE_CAPACITY : 0;
+  out->paths_generated = g->paths_generated;
+  out->paths_executed = g->paths_executed;
+  out->invalidations = g->invalidations;
+  return true;
+}
+bool blink_gem_machine_invalidate_code(struct blink_gem_machine* g,
+                                       uint64_t address, uint64_t size) {
+  uint64_t page, last;
+  if (!g || !size || !canonical(address) || size - 1 > UINT64_MAX - address ||
+      !canonical(address + size - 1))
+    return false;
+  page = address & ~UINT64_C(4095);
+  last = (address + size - 1) & ~UINT64_C(4095);
+  if (g->engine_mode == BLINK_GEM_ENGINE_JIT) {
+    for (;;) {
+      ResetJitPage(&g->system->jit, page);
+      if (page == last) break;
+      page += 4096;
+    }
+  }
+  ResetInstructionCache(g->machine);
+  ++g->invalidations;
+  return true;
 }
