From 953373784b3a6ec550d368ebcdde5326ac02a6be Mon Sep 17 00:00:00 2001
From: Avery Felts <averyfelts@users.noreply.github.com>
Date: Sun, 12 Jul 2026 13:20:51 -0600
Subject: [PATCH 7/7] ntdll: execute native ARM64 threads through GEM

---
 dlls/ntdll/ntdll.spec          |   2 +
 dlls/ntdll/signal_arm64.c      |  11 +
 dlls/ntdll/unix/env.c          |   6 +
 dlls/ntdll/unix/gem.c          |   6 +
 dlls/ntdll/unix/loader.c       |  19 +-
 dlls/ntdll/unix/signal_arm64.c | 386 ++++++++++++++++++++++++++++++++-
 dlls/ntdll/unix/virtual.c      |  47 +++-
 7 files changed, 472 insertions(+), 5 deletions(-)

diff --git a/dlls/ntdll/ntdll.spec b/dlls/ntdll/ntdll.spec
index 0b6d9b2..4cec6ec 100644
--- a/dlls/ntdll/ntdll.spec
+++ b/dlls/ntdll/ntdll.spec
@@ -1767,6 +1767,8 @@
 @ extern -private __wine_syscall_dispatcher
 @ extern -private __wine_unix_call_dispatcher
 @ extern -private -arch=arm64ec __wine_unix_call_dispatcher_arm64ec
+@ cdecl -private -arch=arm64 __wine_gem_syscall_dispatcher()
+@ cdecl -private -arch=arm64 __wine_gem_unix_call_dispatcher()
 @ extern -private __wine_unixlib_handle
 
 # Debugging
diff --git a/dlls/ntdll/signal_arm64.c b/dlls/ntdll/signal_arm64.c
index 056f875..72cc50e 100644
--- a/dlls/ntdll/signal_arm64.c
+++ b/dlls/ntdll/signal_arm64.c
@@ -843,6 +843,17 @@ void WINAPI LdrInitializeThunk( CONTEXT *context, ULONG_PTR unk2, ULONG_PTR unk3
     NtContinue( context, TRUE );
 }
 
+/* Guest-resident GEM boundaries.  The Unix loader installs these addresses in
+ * the exported dispatcher slots on macOS so no PE stub can branch into a host
+ * Mach-O text address. */
+__ASM_GLOBAL_FUNC( __wine_gem_syscall_dispatcher,
+                   "svc #0\n\t"
+                   "ret" )
+
+__ASM_GLOBAL_FUNC( __wine_gem_unix_call_dispatcher,
+                   "svc #0x5749\n\t"
+                   "ret" )
+
 
 /***********************************************************************
  *           process_breakpoint
diff --git a/dlls/ntdll/unix/env.c b/dlls/ntdll/unix/env.c
index 460888b..bdd3e51 100644
--- a/dlls/ntdll/unix/env.c
+++ b/dlls/ntdll/unix/env.c
@@ -1600,7 +1600,13 @@ static void run_wineboot( WCHAR *env, SIZE_T size )
     handles[count++] = process;
 
 wait:
+#ifdef __APPLE__
+    /* Checked GEM execution is intentionally unoptimized and may require more
+     * than Wine's native five-minute bootstrap window on Apple Silicon. */
+    timeout.QuadPart = (ULONGLONG)20 * 60 * 1000 * -10000;
+#else
     timeout.QuadPart = (ULONGLONG)5 * 60 * 1000 * -10000;
+#endif
     if (NtWaitForMultipleObjects( count, handles, WaitAny, FALSE, &timeout ) == WAIT_TIMEOUT)
         ERR( "boot event wait timed out\n" );
     while (count) NtClose( handles[--count] );
diff --git a/dlls/ntdll/unix/gem.c b/dlls/ntdll/unix/gem.c
index ae9f336..abf82d9 100644
--- a/dlls/ntdll/unix/gem.c
+++ b/dlls/ntdll/unix/gem.c
@@ -37,6 +37,10 @@ WINE_DEFAULT_DEBUG_CHANNEL(gem);
 
 static struct gem_wine_process *gem_process;
 
+extern enum gem_wine_status gem_signal_boundary(
+    void *opaque, const struct gem_wine_boundary_request *request,
+    struct gem_wine_boundary_response *response);
+
 static NTSTATUS gem_status(enum gem_wine_status status)
 {
     switch (status)
@@ -99,6 +103,8 @@ NTSTATUS gem_thread_init(struct thread_data *data)
     config.version = GEM_WINE_THREAD_CONFIG_VERSION;
     config.struct_size = sizeof(config);
     config.teb = (uint64_t)(uintptr_t)data->teb;
+    config.boundary = gem_signal_boundary;
+    config.opaque = data;
     status = gem_wine_thread_create(gem_process, &config, &data->gem_thread);
     if (status == GEM_WINE_OK) TRACE("thread created teb=%p\n", data->teb);
     return gem_status(status);
diff --git a/dlls/ntdll/unix/loader.c b/dlls/ntdll/unix/loader.c
index 9a2a6db..02225e4 100644
--- a/dlls/ntdll/unix/loader.c
+++ b/dlls/ntdll/unix/loader.c
@@ -1555,6 +1555,10 @@ static void load_ntdll_functions( HMODULE module )
     void **p__wine_syscall_dispatcher;
     void **p__wine_unix_call_dispatcher;
     void **p__wine_unix_call_dispatcher_arm64ec = NULL;
+#ifdef __APPLE__
+    void *p__wine_gem_syscall_dispatcher = NULL;
+    void *p__wine_gem_unix_call_dispatcher = NULL;
+#endif
     unixlib_handle_t *p__wine_unixlib_handle;
     const IMAGE_EXPORT_DIRECTORY *exports;
 
@@ -1577,12 +1581,20 @@ static void load_ntdll_functions( HMODULE module )
     GET_FUNC( __wine_syscall_dispatcher );
     GET_FUNC( __wine_unix_call_dispatcher );
     GET_FUNC( __wine_unixlib_handle );
