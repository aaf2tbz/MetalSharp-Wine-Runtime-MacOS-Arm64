diff --git a/dlls/ntdll/unix/signal_arm64.c b/dlls/ntdll/unix/signal_arm64.c
index 522ade3..8594b94 100644
--- a/dlls/ntdll/unix/signal_arm64.c
+++ b/dlls/ntdll/unix/signal_arm64.c
@@ -59,7 +59,17 @@
 #include "unix_private.h"
 #include "wine/debug.h"
 
+#if defined(__APPLE__)
+struct gem_callback_state;
+
+#include <metalsharp/gem/wine_bridge.h>
+#include "wine/unixlib.h"
+#endif
+
 WINE_DEFAULT_DEBUG_CHANNEL(seh);
+#if defined(__APPLE__)
+WINE_DECLARE_DEBUG_CHANNEL(gem);
+#endif
 
 #define NTDLL_DWARF_H_NO_UNWINDER
 #include "dwarf.h"
@@ -67,6 +77,13 @@ WINE_DEFAULT_DEBUG_CHANNEL(seh);
 struct arm64_thread_data
 {
     BOOL suspend_pending;
+#if defined(__APPLE__)
+    BOOL gem_context_pending;
+    BOOL gem_logged_syscall;
+    BOOL gem_logged_unix_call;
+    BOOL gem_logged_callback;
+    struct gem_callback_state *gem_callback;
+#endif
 };
 
 C_ASSERT( sizeof(struct arm64_thread_data) <= sizeof(((struct teb_data *)0)->cpu_data) );
@@ -197,6 +214,282 @@ struct syscall_frame
 
 C_ASSERT( sizeof( struct syscall_frame ) == 0x330 );
 
+#if defined(__APPLE__)
+struct gem_callback_state
+{
+    struct gem_callback_state *previous;
+    void **ret_ptr;
+    ULONG *ret_len;
+    struct syscall_frame frame;
+};
+
+static void syscall_frame_fixup_for_fastpath( struct syscall_frame *frame );
+void DECLSPEC_NORETURN gem_signal_run(void);
+
+static void gem_context_from_frame( struct gem_thread_context *context,
+                                    const struct syscall_frame *frame, TEB *teb )
+{
+    unsigned int i;
+
+    memset( context, 0, sizeof(*context) );
+    context->layout_version = GEM_CONTEXT_LAYOUT_VERSION;
+    context->context_size = GEM_THREAD_CONTEXT_EXPECTED_SIZE;
+    for (i = 0; i < 29; ++i) context->x[i] = frame->x[i];
+    context->x[29] = frame->fp;
+    context->x[30] = frame->lr;
+    context->sp = frame->sp;
+    context->pc = frame->pc;
+    context->nzcv = frame->cpsr & 0xf0000000u;
+    context->fpcr = frame->fpcr;
+    context->fpsr = frame->fpsr;
+    memcpy( context->v, frame->v, sizeof(context->v) );
+    context->teb = (uint64_t)(uintptr_t)teb;
+    context->x[18] = context->teb;
+    context->isa = GEM_ISA_ARM64EC;
+}
+
+static BOOL gem_context_to_frame( struct syscall_frame *frame,
+                                  const struct gem_thread_context *context, TEB *teb )
+{
+    unsigned int i;
+
+    if (!context || context->layout_version != GEM_CONTEXT_LAYOUT_VERSION ||
+        context->context_size != GEM_THREAD_CONTEXT_EXPECTED_SIZE ||
+        context->teb != (uint64_t)(uintptr_t)teb || context->x[18] != context->teb ||
+        context->isa != GEM_ISA_ARM64EC || context->reserved0) return FALSE;
+    for (i = 0; i < 29; ++i) frame->x[i] = context->x[i];
+    frame->fp = context->x[29];
+    frame->lr = context->x[30];
+    frame->sp = context->sp;
+    frame->pc = context->pc;
+    frame->cpsr = context->nzcv & 0xf0000000u;
+    frame->fpcr = context->fpcr;
+    frame->fpsr = context->fpsr;
+    memcpy( frame->v, context->v, sizeof(context->v) );
+    frame->restore_flags = CONTEXT_FULL;
+    syscall_frame_fixup_for_fastpath( frame );
+    return TRUE;
+}
+
+static NTSTATUS gem_call_syscall( const struct gem_thread_context *context )
+{
+    typedef ULONG_PTR (*syscall_func)(ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR);
+    SYSTEM_SERVICE_TABLE *table;
+    const ULONG id = context->x[8];
+    const ULONG table_id = (id >> 12) & 3;
+    const ULONG service_id = id & 0xfff;
+    const ULONG_PTR *stack = (const ULONG_PTR *)(uintptr_t)context->sp;
+    ULONG_PTR args[8] = {0};
+    ULONG stack_bytes;
+    syscall_func func;
+
+    table = &KeServiceDescriptorTable[table_id];
+    if (service_id >= table->ServiceLimit) return STATUS_INVALID_SYSTEM_SERVICE;
+    stack_bytes = table->ArgumentTable[service_id];
+    stack_bytes = stack_bytes > 8 * sizeof(ULONG_PTR) ? stack_bytes - 8 * sizeof(ULONG_PTR) : 0;
+    if (stack_bytes > sizeof(args)) return STATUS_INVALID_PARAMETER;
+    if (stack_bytes) memcpy( args, stack, stack_bytes );
+    func = (syscall_func)(uintptr_t)table->ServiceTable[service_id];
+    return func( context->x[0], context->x[1], context->x[2], context->x[3],
+                 context->x[4], context->x[5], context->x[6], context->x[7],
+                 args[0], args[1], args[2], args[3], args[4], args[5], args[6], args[7] );
+}
+
+static void gem_frame_set_upper_simd( struct thread_data *data, struct syscall_frame *frame )
+{
+    struct gem_u128 upper[16];
+    enum gem_wine_status status = gem_wine_thread_get_native_upper_simd( data->gem_thread, upper );
+    if (status != GEM_WINE_OK) abort_thread( status );
+    memcpy( frame->v + 16, upper, sizeof(upper) );
+}
+
+static void gem_frame_get_upper_simd( struct thread_data *data, const struct syscall_frame *frame )
+{
+    struct gem_u128 upper[16];
+    enum gem_wine_status status;
+    memcpy( upper, frame->v + 16, sizeof(upper) );
+    status = gem_wine_thread_set_native_upper_simd( data->gem_thread, upper );
+    if (status != GEM_WINE_OK) abort_thread( status );
+}
+
+void DECLSPEC_NORETURN gem_user_mode_callback_enter( ULONG64 user_sp, void *func, TEB *teb )
+{
+    struct thread_data *data = get_thread_data();
+    struct syscall_frame *frame = get_syscall_frame( data );
+    struct syscall_frame *prev_frame = frame->prev_frame;
+    void *syscall_cfa = frame->syscall_cfa;
+
+    memset( frame, 0, sizeof(*frame) );
+    frame->prev_frame = prev_frame;
+    frame->syscall_cfa = syscall_cfa;
+    frame->sp = user_sp;
+    frame->pc = (ULONG64)func;
+    frame->x[18] = (ULONG64)teb;
+    frame->restore_flags = CONTEXT_FULL;
+    syscall_frame_fixup_for_fastpath( frame );
+    gem_signal_run();
+}
+
+enum gem_wine_status gem_signal_boundary(
+    void *opaque, const struct gem_wine_boundary_request *request,
+    struct gem_wine_boundary_response *response )
+{
+    struct thread_data *data = opaque;
+    struct syscall_frame *frame;
+    EXCEPTION_RECORD rec = {0};
+    NTSTATUS status = STATUS_SUCCESS;
+
+    if (!data || data != get_thread_data() || !data->gem_thread || !request || !response)
+        return GEM_WINE_CALLBACK_ERROR;
+    frame = get_syscall_frame( data );
+    if (!frame || !gem_context_to_frame( frame, &request->context, data->teb ))
+        return GEM_WINE_CALLBACK_ERROR;
+    gem_frame_set_upper_simd( data, frame );
+    response->action = GEM_WINE_BOUNDARY_RESUME;
+
+    switch (request->event)
+    {
+    case GEM_WINE_EVENT_SYSCALL:
+    {
+        struct arm64_thread_data *arm64_data = arm64_thread_data( data );
+        const ULONG64 boundary_pc = frame->pc;
+        status = gem_call_syscall( &request->context );
+        if (!arm64_data->gem_logged_syscall)
+        {
+            TRACE_(gem)("boundary syscall id=%#llx status=%#x pc=%p\n",
+                        (unsigned long long)request->context.x[8], (unsigned int)status,
+                        (void *)(uintptr_t)request->context.pc );
+            arm64_data->gem_logged_syscall = TRUE;
+        }
+        if (frame->pc == boundary_pc)
+        {
+            frame->x[0] = status;
+            frame->pc = frame->lr;
+            frame->lr = frame->x[9];
+        }
+        break;
+    }
+    case GEM_WINE_EVENT_UNIX_CALL:
+    {
+        struct arm64_thread_data *arm64_data = arm64_thread_data( data );
+        const unixlib_entry_t *table = (const unixlib_entry_t *)(uintptr_t)frame->x[0];
+        frame->x[0] = table[frame->x[1]]( (void *)(uintptr_t)frame->x[2] );
+        frame->pc = frame->lr;
+        if (!arm64_data->gem_logged_unix_call)
+        {
+            TRACE_(gem)("boundary unix-call index=%llu status=%#llx\n",
+                        (unsigned long long)frame->x[1], (unsigned long long)frame->x[0] );
+            arm64_data->gem_logged_unix_call = TRUE;
+        }
+        break;
+    }
+    case GEM_WINE_EVENT_MEMORY_FAULT:
+        rec.ExceptionAddress = (void *)(uintptr_t)request->context.pc;
+        rec.NumberParameters = 2;
+        rec.ExceptionInformation[0] = request->stop.access == GEM_WINE_ACCESS_WRITE
+                                      ? EXCEPTION_WRITE_FAULT
+                                      : request->stop.access == GEM_WINE_ACCESS_FETCH
+                                        ? EXCEPTION_EXECUTE_FAULT : EXCEPTION_READ_FAULT;
+        rec.ExceptionInformation[1] = request->stop.fault_address;
+        TRACE_(gem)("boundary memory-fault access=%u address=%p pc=%p\n",
+                    request->stop.access, (void *)(uintptr_t)request->stop.fault_address,
+                    (void *)(uintptr_t)request->context.pc );
+        status = virtual_handle_fault( data, &rec, (void *)(uintptr_t)request->context.sp );
+        if (status && status != STATUS_SUCCESS)
+        {
+            CONTEXT context = { CONTEXT_FULL };
+            NtGetContextThread( GetCurrentThread(), &context );
+            context.Pc = request->context.pc;
+            status = call_user_exception_dispatcher( data, &rec, &context );
+            if (status) return GEM_WINE_CALLBACK_ERROR;
+        }
+        break;
+    case GEM_WINE_EVENT_WINDOWS_EXCEPTION:
+    {
+        CONTEXT context = { CONTEXT_FULL };
+        rec.ExceptionAddress = (void *)(uintptr_t)request->context.pc;
+        rec.ExceptionCode = EXCEPTION_BREAKPOINT;
+        TRACE_(gem)("boundary windows-exception pc=%p\n",
+                    (void *)(uintptr_t)request->context.pc );
+        rec.NumberParameters = 1;
+        NtGetContextThread( GetCurrentThread(), &context );
+        context.Pc = request->context.pc + 4;
+        status = call_user_exception_dispatcher( data, &rec, &context );
+        if (status) return GEM_WINE_CALLBACK_ERROR;
+        break;
+    }
+    case GEM_WINE_EVENT_ASYNC_REQUEST:
+        break;
+    default:
+        response->action = GEM_WINE_BOUNDARY_FAIL;
+        return GEM_WINE_OK;
+    }
+    gem_frame_get_upper_simd( data, frame );
+    gem_context_from_frame( &response->context, frame, data->teb );
+    return GEM_WINE_OK;
+}
+
+void DECLSPEC_NORETURN gem_signal_run(void)
+{
+    struct thread_data *data = get_thread_data();
+    struct arm64_thread_data *arm64_data = arm64_thread_data( data );
+    CHPE_V2_CPU_AREA_INFO *cpu_area = data->teb->ChpeV2CpuAreaInfo;
+    struct syscall_frame *frame = get_syscall_frame( data );
+    struct gem_thread_context context, output;
+    struct gem_wine_run_result result;
+    enum gem_wine_status status;
+
+    gem_context_from_frame( &context, frame, data->teb );
+    gem_frame_get_upper_simd( data, frame );
+    TRACE_(gem)("enter pc=%p sp=%p teb=%p\n", (void *)(uintptr_t)context.pc,
+                (void *)(uintptr_t)context.sp, data->teb );
+    for (;;)
+    {
+        if (cpu_area) cpu_area->InSimulation = TRUE;
+        status = gem_wine_thread_run( data->gem_thread, &context, &output, &result );
+        if (cpu_area) cpu_area->InSimulation = FALSE;
+        TRACE_(gem)("stop status=%s reason=%u event=%u retired=%llu callbacks=%llu pc=%p\n",
+                    gem_wine_status_name(status), result.stop_reason, result.last_event,
+                    (unsigned long long)result.instructions_retired,
+                    (unsigned long long)result.boundary_callbacks,
+                    (void *)(uintptr_t)output.pc );
+        context = output;
+        if (status == GEM_WINE_BUDGET_EXPIRED)
+        {
+            CONTEXT wine_context = { CONTEXT_FULL };
+            context.stop_reason = GEM_STOP_NONE;
+            if (arm64_data->gem_context_pending)
+            {
+                arm64_data->gem_context_pending = FALSE;
+                gem_context_from_frame( &context, frame, data->teb );
+                gem_frame_get_upper_simd( data, frame );
+            }
+            else
+            {
+                if (!gem_context_to_frame( frame, &context, data->teb )) abort_thread(1);
+                gem_frame_set_upper_simd( data, frame );
+            }
+            if (arm64_data->suspend_pending)
+            {
+                NtGetContextThread( GetCurrentThread(), &wine_context );
+                if (signal_set_full_context( &wine_context )) abort_thread(1);
+            }
+            gem_context_from_frame( &context, frame, data->teb );
+            gem_frame_get_upper_simd( data, frame );
+            continue;
+        }
+        if (status == GEM_WINE_TERMINATED) abort_thread( result.exit_status );
+        ERR_(gem)("GEM execution failed closed: %s outcome=%u reason=%u event=%u pc=%p\n",
+                  gem_wine_status_name(status), result.outcome, result.stop_reason,
+                  result.last_event, (void *)(uintptr_t)output.pc );
+        abort_thread(1);
+    }
+}
+#endif
+
 
 #define ESR_ELx_EC(esr)                 (((DWORD64)(esr) >> 26) & 0x3f)
 #define ESR_ELx_EC_IABT_LOW             0x20
@@ -897,9 +1190,16 @@ __ASM_GLOBAL_FUNC( call_user_mode_callback,
                    "stp x7, x8, [x1, #0x110]\n\t" /* frame->prev_frame,syscall_cfa */
                    "ldr w11, [x18, #0x380]\n\t"   /* thread_data->syscall_trace */
                    "cbnz x11, 1f\n\t"
+#if defined(__APPLE__)
+                   "mov sp, x1\n\t"              /* kernel stack */
+                   "mov x2, x18\n\t"             /* teb */
+                   "mov x1, x3\n\t"              /* func */
+                   "bl " __ASM_NAME("gem_user_mode_callback_enter") "\n"
+#else
                    /* switch to user stack */
                    "mov sp, x0\n\t"               /* user_sp */
                    "br x3\n"
+#endif
                    "1:\tmov x19, x18\n\t"         /* teb */
                    "mov x20, x0\n\t"              /* user_sp */
                    "mov x21, x3\n\t"              /* func */
@@ -909,8 +1209,16 @@ __ASM_GLOBAL_FUNC( call_user_mode_callback,
                    "str x0, [x29, #0xc0]\n\t"     /* id */
                    "bl " __ASM_NAME("trace_usercall") "\n\t"
                    "mov x18, x19\n\t"             /* teb */
+#if defined(__APPLE__)
+                   "mov x0, x20\n\t"              /* user_sp */
+                   "mov x1, x21\n\t"              /* func */
+                   "mov x2, x19\n\t"              /* teb */
+                   "bl " __ASM_NAME("gem_user_mode_callback_enter") "\n"
+#else
                    "mov sp, x20\n\t"              /* user_sp */
-                   "br x21" )
+                   "br x21"
+#endif
+                   )
 
 
 /***********************************************************************
@@ -1019,7 +1327,33 @@ NTSTATUS KeUserModeCallback( ULONG id, const void *args, ULONG len, void **ret_p
     stack->sp   = frame->sp;
     stack->pc   = frame->pc;
     memcpy( stack->args_data, args, len );
+#if defined(__APPLE__)
+    {
+        struct arm64_thread_data *arm64_data = arm64_thread_data( data );
+        struct gem_callback_state *callback = malloc( sizeof(*callback) );
+        if (!callback) return STATUS_NO_MEMORY;
+        callback->previous = arm64_data->gem_callback;
+        callback->ret_ptr = ret_ptr;
+        callback->ret_len = ret_len;
+        callback->frame = *frame;
+        arm64_data->gem_callback = callback;
+        if (!arm64_data->gem_logged_callback)
+        {
+            TRACE_(gem)("callback enter id=%u pc=%p return=%p sp=%p\n", id,
+                        pKiUserCallbackDispatcher, (void *)(uintptr_t)callback->frame.pc,
+                        (void *)(uintptr_t)sp );
+            arm64_data->gem_logged_callback = TRUE;
+        }
+        frame->sp = sp;
+        frame->pc = (ULONG64)pKiUserCallbackDispatcher;
+        frame->x[18] = (ULONG64)data->teb;
+        frame->restore_flags |= CONTEXT_FULL;
+        syscall_frame_fixup_for_fastpath( frame );
+        return STATUS_SUCCESS;
+    }
+#else
     return call_user_mode_callback( sp, ret_ptr, ret_len, pKiUserCallbackDispatcher, data->teb );
+#endif
 }
 
 
